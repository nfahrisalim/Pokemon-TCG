<!DOCTYPE html>
<html>
<head>
    <title>Sets - Admin Panel</title>
    <link rel="stylesheet" href="/css/retro-theme.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="app-sidebar">
            <p class="retro-tag">Deck Radar</p>
            <nav class="retro-nav-vertical">
                <a href="/sets">Sets</a>
                <a href="/cards">Manage Cards</a>
                <a href="/auth/logout">Logout</a>
            </nav>
        </aside>

        <main class="app-main">
            <div class="mobile-topbar">
                <span class="mobile-topbar-title">Deck Radar</span>
                <nav class="mobile-topbar-nav">
                    <a class="retro-link" href="/sets">Sets</a>
                    <a class="retro-link" href="/cards">Cards</a>
                    <a class="retro-link" href="/auth/logout">Logout</a>
                </nav>
            </div>

            <div class="retro-shell">
                <h1 class="retro-title">Pokémon Sets</h1>

                <form action="/sets" method="GET" class="retro-form">
                    <div class="retro-field">
                        <label class="retro-label">Search sets</label>
                        <input class="retro-input" type="text" name="search" placeholder="Search sets..." value="<%= search %>">
                    </div>
                    <button class="retro-button" type="submit">Search</button>
                </form>

                <ul class="retro-list retro-list-grid">
                    <% sets.forEach((set, index) => { %>
                        <li class="bento-tile <%= index === 0 ? 'bento-featured' : '' %>">
                            <a href="/sets/<%= set.set_id %>">
                                <strong class="retro-accent"><%= set.set_name %></strong>
                                <div class="retro-meta">Released: <%= set.release_date %></div>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </main>
    </div>
</body>
</html>